OPENAI_API_KEY=your_openai_api_key_here
TEEDOO_API_BASE_URL=https://api.teedoo.app/v1
DEMO_AUTH_ENABLED=false

# ─── Dual-DB runtime switch ───────────────────────────────────────
# Required. "mongo" or "mysql". Decides which backend repositories serve.
DATA_SOURCE=mongo
# Optional per-domain overrides (hybrid mode). Example:
# DATA_SOURCE_HEALTH=mysql

# ─── MongoDB Atlas (Vercel Marketplace) ───────────────────────────
# Auto-provisioned by: vercel integration add mongodb-atlas
MONGODB_URI=
MONGODB_DB=teedoo

# ─── MySQL (Aiven / Vercel Marketplace) ───────────────────────────
# Auto-provisioned once Aiven MySQL integration is installed.
# Format: mysql://user:pass@host:port/dbname?ssl={"rejectUnauthorized":true}
MYSQL_URL=
