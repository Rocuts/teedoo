OPENAI_API_KEY=your_openai_api_key_here
TEEDOO_API_BASE_URL=https://api.teedoo.app/v1
DEMO_AUTH_ENABLED=false

# ─── Seed endpoint (POST /api/seed) ───────────────────────────────
# Bearer token required by the demo-seed endpoint. Generate with
# `openssl rand -hex 32`. NEVER commit the real value. Configure in
# Vercel with `vercel env add SEED_TOKEN`.
SEED_TOKEN=replace_me_with_a_long_random_secret

# ─── Dual-DB runtime switch ───────────────────────────────────────
# Required. "mongo" or "postgres". Decides which backend repositories serve.
DATA_SOURCE=mongo
# Optional per-domain overrides (hybrid mode). Example:
# DATA_SOURCE_HEALTH=postgres

# ─── MongoDB Atlas (Vercel Marketplace) ───────────────────────────
# MONGODB_URI is auto-provisioned by the Atlas integration.
# MONGODB_DB is optional — defaults to "teedoo" in code.
MONGODB_URI=
MONGODB_DB=teedoo

# ─── Supabase Postgres (Vercel Marketplace) ───────────────────────
# Auto-provisioned by the Supabase marketplace integration. Do NOT set by hand
# in production — run `vercel env pull .env.local` after linking.
# Pooled connection (pgbouncer, port 6543) — use in all runtime code.
POSTGRES_URL=
# Direct connection (port 5432) — ONLY for migrations / long transactions.
POSTGRES_URL_NON_POOLING=
# Supabase REST + auth surface (optional — only if you use @supabase/supabase-js).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
